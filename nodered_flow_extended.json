    {
        "id": "nr_accum",
        "type": "function",
        "name": "雷达累积",
        "func": "if (msg.payload && msg.payload.type === 'delete_record') {\n    var rid = msg.payload.recordId;\n    var records = flow.get('records') || [];\n    if (rid >= 0 && rid < records.length) {\n        records.splice(rid, 1);\n        for (var k = 0; k < records.length; k++) { records[k].id = k; }\n        flow.set('records', records);\n        var opts = [{label: '-- 选择记录 --', value: -1}];\n        for (var k = 0; k < records.length; k++) {\n            var r = records[k];\n            opts.push({label: '#' + r.id + ' ' + r.time + ' (' + r.pointCount + '点)', value: r.id});\n        }\n        return [{payload: {radarData: (function(){var rd=flow.get('radarData')||new Array(181).fill(0);var o=[];for(var i=0;i<=180;i++){o[i]=Array.isArray(rd[i])?rd[i].slice():(rd[i]>0?[rd[i]]:[]);}return o;})(), currentAngle: 0, currentDistance: 0, warning: 0, blocked: 0}},\n                {payload: {type: 'update_list', recordId: -1, records: records, options: opts}}];\n    }\n    return null;\n}\nvar radarData = flow.get('radarData') || new Array(181).fill(0);\nvar records = flow.get('records') || [];\nvar lastAngle = flow.get('lastAngle') || -1;\nvar direction = flow.get('direction') || 0;\nvar angle = Number(msg.payload.angle);\nvar distance = Number(msg.payload.distance);\nvar warning = Number(msg.payload.warning) || 0;\nvar blocked = Number(msg.payload.blocked) || 0;\nvar clearCmd = Number(msg.payload.clear) || 0;\nif (angle >= 0 && angle <= 180) {if(!Array.isArray(radarData[angle]))radarData[angle]=[];if(distance>2){radarData[angle].push(distance);if(radarData[angle].length>5)radarData[angle].shift();}}\nif (clearCmd === 1) {\n    var snap = []; for (var si = 0; si <= 180; si++) { snap[si] = Array.isArray(radarData[si]) ? radarData[si].slice() : []; }\n    var pts = [];\n    for (var a = 0; a <= 180; a++) {\n        var arr = Array.isArray(radarData[a]) ? radarData[a] : [];\n        for (var j = 0; j < arr.length; j++) {\n            var dist = arr[j];\n            if (dist > 2.0 && dist <= 250.0) {\n                pts.push({angle: a, distance: parseFloat(dist.toFixed(1))});\n            }\n        }\n    }\n    var now = new Date();\n    var ts = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0') + ':' + now.getSeconds().toString().padStart(2,'0');\n    records.push({id: records.length, time: ts, points: pts, pointCount: pts.length, snapshot: snap});\n    if (records.length > 50) records = records.slice(-50);\n    flow.set('records', records);\n    var opts = [{label: '-- 选择记录 --', value: -1}];\n    for (var i = 0; i < records.length; i++) { var r = records[i]; opts.push({label: '#' + r.id + ' ' + r.time + ' (' + r.pointCount + '点)', value: r.id}); }\n    for (var ci = 0; ci <= 180; ci++) { radarData[ci] = []; }\n    flow.set('radarData', radarData);\n    flow.set('lastAngle', -1);\n    flow.set('direction', 0);\n    return [{payload: {radarData: radarData.slice(), currentAngle: 0, currentDistance: 0, warning: 0, blocked: 0}},\n            {payload: {type: 'update_list', recordId: -1, records: records, options: opts}}];\n}\nvar scanCompleted = false;\nif (lastAngle >= 0) {\n    if (direction === 0 && angle < lastAngle && lastAngle > 170) { direction = 1; scanCompleted = true; }\n    else if (direction === 1 && angle > lastAngle && lastAngle < 10) { direction = 0; scanCompleted = true; }\n}\nflow.set('lastAngle', angle);\nflow.set('direction', direction);\nflow.set('radarData', radarData);\nvar od=[];for(var ii=0;ii<=180;ii++){od[ii]=Array.isArray(radarData[ii])?radarData[ii].slice():(radarData[ii]>0?[radarData[ii]]:[]);}var out1 = {payload: {radarData: od, currentAngle: angle, currentDistance: distance, warning: warning, blocked: blocked}};\nreturn [out1, null];",
        "outputs": 2,
        "noerr": 0,
