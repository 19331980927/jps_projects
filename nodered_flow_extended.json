    {
        "id": "nr_chart",
        "type": "ui_template",
        "name": "极坐标雷达图",
        "group": "nr_group",
        "order": 1,
        "width": "12",
        "height": "10",
        "format": "<style>\n#rcWrap { position:relative; width:100%; max-width:620px; margin:0 auto }\n#rcCanvas { display:block; width:100%; height:auto; background:#0a0a1a; border-radius:8px; cursor:crosshair; touch-action:none }\n#rcTip { position:absolute; background:rgba(0,0,0,0.85); color:#0f0; padding:6px 12px; border:1px solid #0f0; border-radius:4px; font:14px monospace; pointer-events:none; display:none; z-index:10 }\n#rcInfo { margin-top:4px; font:13px monospace; color:#ccc; text-align:center }\n.grn { color:#0f0 } .red { color:#f44 } .blu { color:#4af }\n</style>\n<div id=\"rcWrap\"><canvas id=\"rcCanvas\" width=\"600\" height=\"380\"></canvas><div id=\"rcTip\"></div></div>\n<div id=\"rcInfo\">等待数据...</div>\n<script>\n(function(scope){\nvar cv=document.getElementById('rcCanvas'),cx=cv.getContext('2d'),tip=document.getElementById('rcTip'),inf=document.getElementById('rcInfo');\nvar sa=-1,W=600,H=380,ox=300,oy=345,mR=300,mD=250;\nvar lastData=null,lastCA=0,lastCD=0,lastW=0,lastBl=0;\nvar msgCount=0;\nfunction a2xy(a,d){var r=Math.PI+a*Math.PI/180,rr=(d/mD)*mR;return{x:ox+rr*Math.cos(r),y:oy+rr*Math.sin(r)}}\nfunction x2ad(mx,my){var dx=mx-ox,dy=my-oy,rr=Math.sqrt(dx*dx+dy*dy);if(rr<2)return null;var ra=Math.atan2(dy,dx);if(ra<0)ra+=2*Math.PI;var a=(ra-Math.PI)*180/Math.PI;return{a:a,d:(rr/mR)*mD,r:rr}}\nfunction draw(d,ca,cd,w,bl){\ncx.clearRect(0,0,W,H);\nfor(var dd=50;dd<=mD;dd+=50){var r=(dd/mD)*mR;cx.beginPath();cx.arc(ox,oy,r,Math.PI,2*Math.PI);cx.strokeStyle=dd%100===0?'rgba(0,255,0,0.25)':'rgba(0,255,0,0.1)';cx.lineWidth=dd%100===0?1:0.5;cx.stroke();cx.fillStyle='rgba(0,255,0,0.35)';cx.font='10px monospace';cx.fillText(dd+'cm',ox+r/2-12,oy-4)}\nfor(var aa=0;aa<=180;aa+=30){var p=a2xy(aa,mD*0.92);cx.beginPath();cx.moveTo(ox,oy);cx.lineTo(p.x,p.y);cx.strokeStyle='rgba(0,255,0,0.12)';cx.lineWidth=0.5;cx.stroke();cx.fillStyle='rgba(0,255,0,0.4)';cx.font='11px monospace';cx.textAlign='center';cx.fillText(aa+'deg',p.x,p.y-6)}\ncx.beginPath();cx.arc(ox,oy,mR,Math.PI,2*Math.PI);cx.strokeStyle='rgba(0,255,0,0.3)';cx.lineWidth=1.5;cx.stroke();\nif(!d||!d.length){cx.fillStyle='#555';cx.font='16px monospace';cx.textAlign='center';cx.fillText('等待扫描数据...',ox,oy-40);return}\n\nfor(var a=0;a<=180;a++){var arr=d[a];if(!Array.isArray(arr))arr=arr>0?[arr]:[];for(var j=0;j<arr.length;j++){var v=arr[j];if(v>2&&v<=mD){var p=a2xy(a,v),iw=v<30,is=(a===sa&&j===0);cx.beginPath();cx.arc(p.x,p.y,is?5:(iw?4:3),0,Math.PI*2);cx.fillStyle=is?'#ff0':(iw?'#f44':'#0f0');cx.fill();if(is){cx.strokeStyle='#fff';cx.lineWidth=2;cx.stroke()}}}}\nif(ca>=0&&ca<=180){var pe=a2xy(ca,mR*0.85);cx.beginPath();cx.moveTo(ox,oy);cx.lineTo(pe.x,pe.y);cx.strokeStyle='rgba(255,255,0,0.8)';cx.lineWidth=2;cx.setLineDash([6,3]);cx.stroke();cx.setLineDash([]);cx.beginPath();cx.arc(pe.x,pe.y,5,0,Math.PI*2);cx.fillStyle='#ff0';cx.fill();cx.strokeStyle='rgba(255,255,255,0.8)';cx.lineWidth=1;cx.stroke()}\nvar h='角度:<span class=\"grn\">'+ca+'deg</span> | 距离:<span class=\"grn\">'+(cd?cd.toFixed(1):'---')+'cm</span> | 消息:<span class=\"blu\">'+msgCount+'</span>';if(bl)h+=' | <span class=\"red\">模块被遮挡</span>';else if(w)h+=' | <span class=\"red\">障碍物过近!</span>';if(sa>=0&&d[sa]>0)h+=' | 选中:<span class=\"blu\">'+sa+'deg/'+d[sa].toFixed(1)+'cm</span>';inf.innerHTML=h}\ncv.addEventListener('mousemove',function(e){var r=cv.getBoundingClientRect(),sx=cv.width/r.width,sy=cv.height/r.height,mx=(e.clientX-r.left)*sx,my=(e.clientY-r.top)*sy,res=x2ad(mx,my);if(!res||res.a<0||res.a>180){tip.style.display='none';return}tip.style.display='block';tip.style.left=(e.clientX-r.left+12)+'px';tip.style.top=(e.clientY-r.top-20)+'px';tip.innerHTML='A:'+Math.round(res.a)+'deg D:'+res.d.toFixed(0)+'cm'});\ncv.addEventListener('mouseleave',function(){tip.style.display='none'});\ncv.addEventListener('click',function(e){var r=cv.getBoundingClientRect(),sx=cv.width/r.width,sy=cv.height/r.height,mx=(e.clientX-r.left)*sx,my=(e.clientY-r.top)*sy,res=x2ad(mx,my);if(!res)return;var caa=Math.round(res.a);if(caa<0||caa>180)return;var ni=-1,md=999;var dd=lastData;for(var a=0;a<=180;a++){if(dd&&dd[a]>2&&dd[a]<=mD){var df=Math.abs(a-caa);if(df<md){md=df;ni=a}}}sa=(ni>=0&&md<=10)?ni:-1;draw(lastData||[],lastCA,lastCD,lastW,lastBl)});\nsetInterval(function(){var m=scope.msg;if(m&&m.payload&&m.payload.radarData){var p=m.payload;if(!lastData||p.radarData!==lastData){lastData=p.radarData;msgCount++}lastCA=p.currentAngle!==undefined?p.currentAngle:lastCA;lastCD=p.currentDistance!==undefined?p.currentDistance:lastCD;lastW=p.warning!==undefined?p.warning:lastW;lastBl=p.blocked!==undefined?p.blocked:lastBl}if(lastData){draw(lastData,lastCA,lastCD,lastW,lastBl)}},100)\n})(scope);\n</script>",
