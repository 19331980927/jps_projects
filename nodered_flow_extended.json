        "name": "过滤非JSON行",
        "func": "var s = msg.payload;\nif (Buffer.isBuffer(s)) s = s.toString('utf8');\ns = s.trim();\nif (typeof s === 'string') {\n    try {\n        msg.payload = JSON.parse(s);\n        return msg;\n    } catch(e) {}\n}\nreturn null;",
