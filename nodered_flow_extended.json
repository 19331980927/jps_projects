    {
        "id": "nr_records",
        "type": "ui_template",
        "name": "记录浏览",
        "group": "nr_group",
        "order": 4,
        "width": "8",
        "height": "8",
        "format": "<style>\n#rs{display:flex;gap:8px;align-items:center;margin-bottom:8px;flex-wrap:wrap}\n#rs select{flex:1;min-width:180px;padding:6px 10px;font-size:14px;border:1px solid #555;border-radius:4px;background:#1a1a2e;color:#0f0;font-family:monospace;cursor:pointer}\n#rs button{padding:6px 14px;font-size:13px;border:1px solid #555;border-radius:4px;background:#1a1a2e;color:#0f0;cursor:pointer;font-family:monospace}\n#rs button:hover{background:#2a2a4e}\n#rs label{color:#aaa;font-size:13px;font-family:monospace}\n#rtw{max-height:260px;overflow-y:auto;border:1px solid #333;border-radius:4px}\n#rt{width:100%;border-collapse:collapse;font-family:monospace;font-size:12px}\n#rt th{position:sticky;top:0;background:#1a1a2e;color:#0f0;padding:6px 10px;text-align:left;border-bottom:2px solid #0f0}\n#rt td{padding:4px 10px;border-bottom:1px solid #222;color:#ccc}\n#rt tr:hover td{background:rgba(0,255,0,0.08);color:#fff}\n#rt .w td{color:#f44}\n#ri{margin-top:6px;font:12px monospace;color:#888}\n#re{color:#555;text-align:center;padding:40px 0;font:14px monospace}\n</style>\n<div id=\"rs\"><label>记录:</label><select id=\"rsel\"><option value=\"-1\">-- 选择记录 --</option></select><button id=\"rdel\">删除</button></div>\n<div id=\"rtw\">\n<div id=\"re\">等待记录数据...</div>\n<table id=\"rt\" style=\"display:none\"><thead><tr><th>角度</th><th>距离(cm)</th><th>状态</th></tr></thead><tbody id=\"rtb\"></tbody></table>\n</div>\n<div style=\"margin-top:8px;display:none\" id=\"rchart\"><canvas id=\"rsCanvas\" width=\"300\" height=\"200\" style=\"background:#0a0a1a;border-radius:4px;width:100%;height:auto\"></canvas></div>\n<div id=\"ri\"></div>\n<script>\n(function(scope){\nvar sel=document.getElementById('rsel'),tb=document.getElementById('rtb'),tbl=document.getElementById('rt'),em=document.getElementById('re'),inf=document.getElementById('ri'),del=document.getElementById('rdel'),recs=[];\nfunction drawSnapshot(s){var cv=document.getElementById(\"rsCanvas\");if(!cv||!s)return;var cx=cv.getContext(\"2d\"),W=300,H=200,ox=150,oy=180,mR=150,mD=250;cx.clearRect(0,0,W,H);for(var dd=50;dd<=mD;dd+=50){var r=(dd/mD)*mR;cx.beginPath();cx.arc(ox,oy,r,Math.PI,2*Math.PI);cx.strokeStyle=dd%100===0?\"rgba(0,255,0,0.3)\":\"rgba(0,255,0,0.1)\";cx.lineWidth=dd%100===0?1:0.5;cx.stroke();cx.fillStyle=\"rgba(0,255,0,0.4)\";cx.font=\"8px monospace\";cx.fillText(dd+\"cm\",ox+r/2-12,oy-4)}cx.beginPath();cx.arc(ox,oy,mR,Math.PI,2*Math.PI);cx.strokeStyle=\"rgba(0,255,0,0.35)\";cx.lineWidth=1;cx.stroke();function a2xy(a,d){var r=Math.PI+a*Math.PI/180,rr=(d/mD)*mR;return{x:ox+rr*Math.cos(r),y:oy+rr*Math.sin(r)}}for(var a=0;a<=180;a++){var arr=s[a];if(!Array.isArray(arr))arr=arr>0?[arr]:[];for(var j=0;j<arr.length;j++){var v=arr[j];if(v>2&&v<=mD){var p=a2xy(a,v),iw=v<30;cx.beginPath();cx.arc(p.x,p.y,iw?3:2,0,Math.PI*2);cx.fillStyle=iw?\"#f44\":\"#0f0\";cx.fill()}}}var ch=document.getElementById(\"rchart\");if(ch)ch.style.display=\"block\"}\nfunction render(pts, snap){tb.innerHTML='';if(!pts||!pts.length){em.style.display='block';tbl.style.display='none';inf.textContent='该记录无有效数据点';return}\nem.style.display='none';tbl.style.display='';var h='';\nfor(var i=0;i<pts.length;i++){var p=pts[i];h+='<tr'+(p.distance<30?' class=\"w\"':'')+'><td>'+p.angle+'deg</td><td>'+p.distance.toFixed(1)+'</td><td>'+(p.distance<30?'过近':'正常')+'</td></tr>'}\ntb.innerHTML=h;inf.textContent='共 '+pts.length+' 个点位'}\nfunction updOpts(opts){sel.innerHTML='';if(!opts)return;for(var i=0;i<opts.length;i++){var o=document.createElement('option');o.value=opts[i].value;o.textContent=opts[i].label;sel.appendChild(o)}}\nsel.addEventListener('change',function(){var id=parseInt(sel.value);if(id<0||!recs[id]){render([]);return}var r=recs[id];drawSnapshot(r.snapshot);render(r.points)});\ndel.addEventListener('click',function(){var id=parseInt(sel.value);if(id>=0&&recs[id]){scope.send({payload:{type:'delete_record',recordId:id}})}});\nscope.$watch('msg',function(msg){if(!msg||!msg.payload)return;var p=msg.payload;if(p.type==='update_list'&&p.options){recs=p.records||[];updOpts(p.options);var cv=parseInt(sel.value);if(cv>=0&&recs[cv]){render(recs[cv].points)}else{render([])}}},true);\n})(scope);\n</script>",
